# Required
AVD_NAME=pixel-android-36-google-apis
SYS_IMG_PKG='system-images;android-36;google_apis'

# avdmanager create avd mappings
AVDMANAGER_FORCE=true
AVDMANAGER_DEVICE=pixel
AVDMANAGER_PATH=
AVDMANAGER_TAG=
AVDMANAGER_SDCARD=

# Answer "yes" to the "custom hardware profile" prompt when enabled.
AVDMANAGER_USE_CUSTOM_HARDWARE_PROFILE=false
